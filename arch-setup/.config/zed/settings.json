// command palette (cmd-shift-p / ctrl-shift-p)
{
  "terminal": {
    "font_weight": 400.0,
    "font_size": 15.0
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 500
    }
  },
  "icon_theme": "Zed (Default)",
  "ui_font_size": 10.0,
  "buffer_font_size": 8.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Ayu Dark",
  },
}
