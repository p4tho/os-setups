{
  "layer": "top",
  "position": "top",
  "height": 30,

  "modules-left": ["sway/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["battery"],

  "clock": {
    "format": "{:%a %b %d  %I:%M %p}"
  },

  "battery": {
    "bat": "BAT1",
    "adapter": "AC",
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": " {capacity}%",
    "format-icons": [
      "",
      "",
      "",
      "",
      ""
    ]
  }
}
